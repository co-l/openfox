#!/bin/sh

STAGED=$(git diff --cached --name-only --diff-filter=d)
[ -n "$STAGED" ] && echo "$STAGED" | xargs npx prettier --write --ignore-unknown 1>/dev/null 2>&1
git add -u

script_dir=$(dirname "$0")/..
. "$script_dir/scripts/parallel-exit-on-failure.sh"

echo "  Running checks..."

parallel_exit_on_failure \
  "lint"      "npm run lint" \
  "typecheck" "npm run typecheck" \
  "duplicate" "npm run duplicate" \
  "test"      "npm test"
