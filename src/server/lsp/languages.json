[
  {
    "id": "typescript",
    "name": "TypeScript",
    "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs"],
    "serverCommand": "typescript-language-server",
    "serverArgs": ["--stdio"],
    "rootPatterns": ["tsconfig.json", "jsconfig.json", "package.json"],
    "languageIds": {
      ".ts": "typescript",
      ".tsx": "typescriptreact",
      ".js": "javascript",
      ".jsx": "javascriptreact",
      ".mjs": "javascript",
      ".cjs": "javascript"
    }
  },
