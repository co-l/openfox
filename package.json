{
  "name": "openfox",
  "version": "1.2.2",
  "description": "Local-LLM-first agentic coding assistant",
  "type": "module",
  "bin": {
    "openfox": "./dist/cli/index.js",
    "openfox-dev": "./dist/cli/dev.js"
  },
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "dist/**/*.md",
    "package.json"
  ],
  "scripts": {
    "dev": "OPENFOX_DEV=true tsx watch src/cli/dev.ts --no-browser",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "FORCE_COLOR=1 npm run build:server && FORCE_COLOR=1 npm run build:web",
    "build:server": "FORCE_COLOR=1 tsup && mkdir -p dist/skill-defaults dist/command-defaults dist/agent-defaults dist/workflow-defaults && cp src/server/skills/defaults/*.md dist/skill-defaults/ && cp src/server/commands/defaults/*.md dist/command-defaults/ && cp src/server/agents/defaults/*.md dist/agent-defaults/ && cp src/server/workflows/defaults/*.json dist/workflow-defaults/ && cp package.json dist/",
    "build:web": "cd web && FORCE_COLOR=1 vite build --outDir ../dist/web",
    "start": "node dist/cli/index.js",
    "start:dev": "node dist/cli/dev.js",
    "test": "vitest run --reporter=dot --silent=passed-only && vitest run --reporter=dot --silent=passed-only --config e2e/vitest.config.ts",
    "test:unit": "vitest run --reporter=dot --silent=passed-only",
    "test:e2e": "vitest run --reporter=dot --silent=passed-only --config e2e/vitest.config.ts",
    "test:playwright": "playwright test --config=e2e-playwright/playwright.config.ts",
    "test:playwright:ui": "playwright test --config=e2e-playwright/playwright.config.ts --ui",
    "test:playwright:headed": "playwright test --config=e2e-playwright/playwright.config.ts --headed",
    "test:cov": "vitest run --reporter=dot --silent=passed-only --coverage && vitest run --reporter=dot --silent=passed-only --config e2e/vitest.config.ts --coverage",
    "test:cov:unit": "vitest run --reporter=dot --silent=passed-only --coverage",
    "test:cov:e2e": "vitest run --reporter=dot --silent=passed-only --config e2e/vitest.config.ts --coverage",
    "typecheck": "npm run typecheck:server && npm run typecheck:web",
    "typecheck:server": "tsc --noEmit",
    "typecheck:web": "cd web && tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "bash-language-server": "^5.4.2",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "ignore": "^7.0.5",
    "node-pty": "^1.2.0-beta.12",
    "open": "^11.0.0",
    "openai": "^6.33.0",
    "pyright": "^1.1.408",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "sql-language-server": "^1.7.1",
    "turndown": "^7.2.2",
    "typescript": "^5.8.2",
    "typescript-language-server": "^5.1.3",
    "vite": "^6.1.0",
    "vscode-jsonrpc": "^8.2.1",
    "vscode-langservers-extracted": "^4.10.0",
    "vscode-languageserver-protocol": "^3.17.5",
    "wouter": "^3.9.0",
    "ws": "^8.20.0",
    "yaml-language-server": "^1.15.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.1",
    "prettier": "^3.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --no-warn-ignored"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
